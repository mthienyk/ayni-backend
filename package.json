{
  "name": "ayni-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:deploy": "node scripts/db-migrate.mjs",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "job": "tsx src/jobs/run.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1056.0",
    "@aws-sdk/s3-request-presigner": "^3.1056.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@node-rs/argon2": "^2.0.2",
    "apple-signin-auth": "^2.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "google-auth-library": "^10.6.2",
    "nanoid": "^5.1.11",
    "openai": "^6.39.1",
    "postgres": "^3.4.9",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "zod": "^4.4.3",
    "drizzle-kit": "^0.31.10",
    "dotenv": "^17.4.2",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/sharp": "^0.32.0",
    "eslint": "^10.4.0",
    "tsx": "^4.22.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
